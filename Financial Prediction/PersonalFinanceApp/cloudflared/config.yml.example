# Copy to config.yml and fill in your tunnel UUID after:
#   cloudflared tunnel create finance-app
# Place the credentials JSON next to this file (see Cloudflare dashboard).
#
# Route DNS in Cloudflare Zero Trust → Networks → Tunnels → your tunnel
# (e.g. dev-finance.example.com → this tunnel).

tunnel: <TUNNEL_UUID>
credentials-file: /etc/cloudflared/<TUNNEL_UUID>.json

ingress:
  # Full stack: nginx serves SPA and proxies /api to backend
  - hostname: dev-finance.example.com
    service: http://frontend:3000
  - service: http_status:404
