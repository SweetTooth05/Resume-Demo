# The frontend does NOT need VITE_GOOGLE_CLIENT_ID.
# Google OAuth client configuration is fetched from the backend at runtime via:
#   GET /api/v1/auth/config
# Set GOOGLE_OAUTH_CLIENT_ID in backend/.env instead.

# Optional: override the API base URL (defaults to same-origin /api/v1 via Vite proxy)
# VITE_API_BASE_URL=http://localhost:8000/api/v1
